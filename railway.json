{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd server && node index.js",
    "healthcheckPath": "/api/leaderboard",
    "restartPolicyType": "ON_FAILURE"
  }
}
